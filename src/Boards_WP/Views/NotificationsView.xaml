<UserControl
    x:Class="Boards_WP.Views.NotificationsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views">



    <!-- we define how the Notifications sidebar should look like  -->
    <Border Background="#F0F0FF" CornerRadius="15" Margin="4">
        <Grid Padding="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- the header of the notifications sidebar (its layout) -->
            <TextBlock Text="Notifications" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="#6A67E1" 
                       Margin="0,0,0,15"/>


            <!-- the actual list of notifications (its layout) -->
            <ListView x:Name="NotificationsList" 
                      Grid.Row="1"
                      SelectionMode="Single"
                      Padding="0">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:NotificationItem">
                        <Grid x:Name="RootGrid">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    
                                    <!-- this is for the moment when the mouse doesn't hover on notification, so nothing should happen -->
                                    <VisualState x:Name="Normal" />

                                    <!-- this describes how the notification should change when on hover (maybe doesn't work properly right now :) -->
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="NotificationCard.BorderBrush" Value="#6A67E1"/>
                                            <Setter Target="NotificationCard.BorderThickness" Value="2"/>
                                            <Setter Target="NotificationCard.Background" Value="#F8F8FF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>


                            <!-- how one single notification looks like -->
                            <!-- it splits the notification in 2 rows: Row 0 is for the message, Row 1 is for the time -->
                            <Border x:Name="NotificationCard"
                                    Background="White" 
                                    BorderBrush="#E0E0FF" 
                                    BorderThickness="1" 
                                    CornerRadius="10" 
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- x:Bind Message displays the actual message -->
                                    <TextBlock Text="{x:Bind Message}" 
                                               FontSize="13" 
                                               Foreground="#333333" 
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>

                                    <!-- x:Bind Time displays the actual time -->
                                    <TextBlock Grid.Column="1" 
                                               Text="{x:Bind Time}" 
                                               FontSize="11" 
                                               Foreground="Gray" 
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>