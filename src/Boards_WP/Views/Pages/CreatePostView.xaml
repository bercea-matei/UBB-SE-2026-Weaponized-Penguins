<Page
    x:Class="Boards_WP.Views.Pages.CreatePostView"
    x:Name="CreatePostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:models="using:Boards_WP.Data.Models"
xmlns:helpers="using:Boards_WP.Helpers"
Background="Transparent">

    <Grid Padding="40">
        <Grid.ColumnDefinitions>
          
            <ColumnDefinition Width="*" />
           
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Spacing="15" MaxWidth="600">
            <TextBlock Text="Create Post" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="white" 
                       Margin="0,0,0,10"/>

            <TextBox x:Name="TitleInput" 
                     Text="{x:Bind ViewModel.PostTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Title" 
                     FontSize="18" 
                     FontWeight="SemiBold" 
                     CornerRadius="8"/>

            <TextBox x:Name="DescriptionInput" 
                     Text="{x:Bind ViewModel.PostDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Text (optional)" 
                     AcceptsReturn="True" 
                     Height="200" 
                     TextWrapping="Wrap" 
                     CornerRadius="8"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <ComboBox x:Name="CategorySelector" 
                          ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          DisplayMemberPath="CategoryName"
                          PlaceholderText="Select Category" 
                          Width="200" 
                          CornerRadius="8"/>

                <TextBox x:Name="TagsInput" 
                         Text="{x:Bind ViewModel.CurrentTagText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Write a tag name" 
                         Width="200"
                         CornerRadius="8"/>

                <Button Content="Add Tag"
                        Command="{x:Bind ViewModel.AddTagCommand}"
                        Background="#6A67E1" Foreground="White" CornerRadius="8"/>
            </StackPanel>

            <ItemsControl ItemsSource="{x:Bind ViewModel.AddedTags, Mode=OneWay}" Margin="0,5,0,5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Tag">
                        <Border CornerRadius="12" Padding="8,4" Background="{x:Bind helpers:ColorHelper.GetBrushForCategory(CategoryBelongingTo.CategoryID), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="{x:Bind TagName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <Button Content="✕" 
                                        Command="{Binding ViewModel.RemoveTagCommand, ElementName=CreatePostPage}"
                                        CommandParameter="{x:Bind}"
                                        Background="Transparent" BorderThickness="0" Foreground="White" Padding="2" FontSize="10" MinWidth="15" MinHeight="15"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" 
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Background="Transparent"
                        Foreground="Gray"
                        Padding="20,12"
                        CornerRadius="10"/>

                <Button Content="Upload Post" 
                        Command="{x:Bind ViewModel.UploadPostCommand}" 
                        Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Padding="40,12" 
                        CornerRadius="10"/>
            </StackPanel>
        </StackPanel>

       
        <Grid Grid.Column="1" Margin="20,50,0,0">
            <Grid Height="200" CornerRadius="12" Background="#E0E0E0">
                <Border CornerRadius="12">
                    <Grid x:Name="PicturePreviewMask" Visibility="Collapsed">
                        <Rectangle RadiusX="12" RadiusY="12">
                            <Rectangle.Fill>
                                <ImageBrush x:Name="PicturePreviewBrush" Stretch="UniformToFill"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>

                <Button HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="ImagePicker_Click"
                        Background="#00000060"
                        CornerRadius="8"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="PictureIcon" Text="📷" FontSize="16"/>
                        <TextBlock Text="Add Photo" Foreground="White" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>