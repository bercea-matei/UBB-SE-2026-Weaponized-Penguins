<Page
    x:Class="Boards_WP.Views.Pages.CreateCommunityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

    <Grid Padding="40">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Start a Community" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#6A67E1"/>

            <StackPanel Orientation="Horizontal" Spacing="15">
                <Button Content="📷" 
                        Width="60" 
                        Height="60" 
                        CornerRadius="30" 
                        Background="#E0E0E0"/>

                <TextBox Text="{x:Bind ViewModel.CommunityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Pick a name..." 
                         FontSize="24" 
                         Width="400" 
                         BorderThickness="0,0,0,1" 
                         Background="Transparent"/>
            </StackPanel>

            <TextBox Text="{x:Bind ViewModel.CommunityDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Add a description..." 
                     AcceptsReturn="True" 
                     Height="150" 
                     TextWrapping="Wrap" 
                     CornerRadius="8"/>

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="Red"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"/>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Cancel" 
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Background="Transparent"
                        Foreground="Gray"
                        Padding="20,12"
                        CornerRadius="10"/>
                
                <Button Content="Create the community" 
                        Command="{x:Bind ViewModel.CreateCommunityCommand}"
                        Background="#6A67E1" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Padding="30,12" 
                        CornerRadius="10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>