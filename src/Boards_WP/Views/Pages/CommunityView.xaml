<Page
    x:Class="Boards_WP.Views.Pages.CommunityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:views="using:Boards_WP.Views"
    Background="Transparent">

    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="10">
                <Grid Height="250">
                    <Border Height="200" VerticalAlignment="Top" CornerRadius="0,0,15,15" Background="#AFAFFF">
                        <Image Source="{x:Bind BannerImage, Mode=OneWay}" Stretch="UniformToFill"/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="30,0,0,10">
                        <PersonPicture ProfilePicture="{x:Bind ProfileImage, Mode=OneWay}" 
                                       DisplayName="{x:Bind CurrentCommunity.Name, Mode=OneWay}"
                                       Height="80" Width="80" BorderBrush="White" BorderThickness="4"/>
                        
                        <StackPanel Margin="15,40,0,0">
                            <TextBlock Text="{x:Bind CurrentCommunity.Name, Mode=OneWay}" 
                                       FontSize="28" FontWeight="Bold" Foreground="Black"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind MemberCountText, Mode=OneWay}" 
                                           FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>

                                <!-- show join button only if user is member of the community -->
                                <Button Content="Join Community" 
                                        Click="JoinButton_Click"
                                        Background="#6A67E1" Foreground="White" CornerRadius="8"
                                        Visibility="{x:Bind InverseBoolToVisibility(IsMember), Mode=OneWay}"/>

                                <!-- if the user is a member, then the join button dissapears, and two more buttons appear -->
                                <StackPanel Orientation="Horizontal" Spacing="8" 
                                            Visibility="{x:Bind BoolToVisibility(IsMember), Mode=OneWay}">
                                    <Button Content="Create Post" Click="CreatePostButton_Click"
                                            Background="White" BorderBrush="#6A67E1" BorderThickness="1" CornerRadius="8"/>
                                    <Button Content="Leave Community" Click="LeaveButton_Click"
                                            Background="#FFE0E0" Foreground="Red" BorderBrush="Red" BorderThickness="1" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" CornerRadius="12" Margin="20,0" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <TextBlock Text="{x:Bind CurrentCommunity.Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="15"/>
                </Border>

                <ItemsControl ItemsSource="{x:Bind CommunityPosts, Mode=OneWay}" Margin="20,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Post">
                            <views:PostPreviewForm PostData="{x:Bind}" Margin="0,0,0,15"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>