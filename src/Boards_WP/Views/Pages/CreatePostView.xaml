<Page
    x:Class="Boards_WP.Views.Pages.CreatePostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

    <Grid Padding="40">
        <StackPanel Spacing="15" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Create Post" FontSize="32" FontWeight="Bold" Foreground="#6A67E1" Margin="0,0,0,10"/>

            <TextBox x:Name="TitleInput" PlaceholderText="Title" FontSize="18" FontWeight="SemiBold" CornerRadius="8"/>
            
            <TextBox x:Name="DescriptionInput" PlaceholderText="Text (optional)" 
                     AcceptsReturn="True" Height="200" TextWrapping="Wrap" CornerRadius="8"/>

            <TextBox x:Name="TagsInput" PlaceholderText="Add tags (e.g. tech, ubb, fun)" CornerRadius="8"/>

            <Button Content="Upload Post" Click="UploadPost_Click" 
                    Background="#6A67E1" Foreground="White" FontWeight="Bold"
                    Padding="40,12" CornerRadius="10" HorizontalAlignment="Right" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Page>