<Page
    x:Class="Boards_WP.Views.Pages.FullPostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Boards_WP.Views"
    xmlns:models="using:Boards_WP.Data.Models"
    Background="Transparent">

    <Grid>

        <!-- because there can be many comments belonging to a post, we added a scroll bar to scroll through all the commments -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <!-- this is for stacking the "back" button and the post attributes on top of one another -->
            <StackPanel Margin="0,0,10,0">

                <!-- calling the Back_Click function from .xaml.cs when the "Back" button gets clicked -->
                <Button Click="Back_Click" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Margin="0,0,0,10"
                        Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" />
                        <TextBlock Text=" Back to Feed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <!-- reusing the preview form of the post (very important, it will enable us to act with the post in full view as if it is in preview form)-->
                <!-- for example, this allows us to increment/decrement the score of a post in both its preview and full post views -->
                <views:PostPreviewForm x:Name="FullPostHeader" Margin="0,0,0,20"/>
                
                <ItemsControl ItemsSource="{x:Bind PostComments, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Comment">
                            <views:CommentView CommentData="{x:Bind}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>