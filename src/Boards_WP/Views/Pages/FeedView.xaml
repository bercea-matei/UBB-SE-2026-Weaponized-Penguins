<Page
    x:Class="Boards_WP.Views.Pages.FeedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Boards_WP.Views"
    xmlns:viewmodels="using:Boards_WP.ViewModels"
    xmlns:models="using:Boards_WP.Data.Models"
    Background="Transparent">


    <!-- SelectionMode="None" disables the highlight effect when a post is clicked -->
    <Grid>
        <ListView ItemsSource="{x:Bind ViewModel.PostsList, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:PostPreviewViewModel">
            
                    <views:PostPreviewForm ViewModel="{x:Bind}" />
            
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>