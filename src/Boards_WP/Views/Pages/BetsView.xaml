<Page
    x:Class="Boards_WP.Views.Pages.BetsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views"
    xmlns:models="using:Boards_WP.Data.Models"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#1A1A2E" CornerRadius="8,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Weaponized Betting" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       Padding="20"/>

            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Spacing="25" 
                        Margin="0,0,25,0"> <HyperlinkButton Content="Home" 
                                 Foreground="White" 
                                 FontSize="16" 
                                 Command="{x:Bind ViewModel.ShowHomeCommand, Mode=OneWay}"
                                 Opacity="{x:Bind ViewModel.HomeTabOpacity, Mode=OneWay}"
                                 Padding="0"/>

                <HyperlinkButton Content="Your bets" 
                                 Foreground="White" 
                                 FontSize="16" 
                                 Command="{x:Bind ViewModel.ShowUserBetsCommand, Mode=OneWay}"
                                 Opacity="{x:Bind ViewModel.UserBetsTabOpacity, Mode=OneWay}"
                                 Padding="0"/>
            </StackPanel>

            <Button Grid.Column="2" 
                    Content="Create New Bet" 
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}"
                    Command="{x:Bind ViewModel.CreateBetCommand, Mode=OneWay}"/>
        </Grid>

        <ListView Grid.Row="1" 
                  ItemsSource="{x:Bind ViewModel.FilteredBets, Mode=OneWay}" 
                  Padding="20" 
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Bet">
                    <local:BetItemControl BetData="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>