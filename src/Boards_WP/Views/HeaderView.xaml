<UserControl
    x:Class="Boards_WP.Views.HeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!-- this is for a more modern design of the search bar  -->
    <UserControl.Resources>
        <Thickness x:Key="AutoSuggestBoxBorderThicknessFocused">0</Thickness>
        <SolidColorBrush x:Key="AutoSuggestBoxBorderBrushFocused" Color="Transparent"/>
        <SolidColorBrush x:Key="AutoSuggestBoxBottomBorderBrushFocused" Color="Transparent"/>
    </UserControl.Resources>
    
    
    <!-- creates the container for the header -->
    <!-- the header is divided into 2 parts: the logo and the search bar, each getting a column of the grid -->
    <Grid Background="#E6E2FF" Height="80" Padding="20,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- logo properties -->
        <Image Source="ms-appx:///Assets/WPLogo.png" 
               Width="200" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Center"
               Margin="40,0,0,5"/>
              
        <!-- search bar properties -->
        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="20" 
                Margin="0,0,120,0" 
                Height="40" 
                VerticalAlignment="Center"
                MaxWidth="800"
                HorizontalAlignment="Stretch">


            <!-- the actual search input -->
            <AutoSuggestBox PlaceholderText="Search communities..."
                            QueryIcon="Find"
                            Background="Transparent"
                            BorderThickness="0" VerticalAlignment="Center" 
                            HorizontalAlignment="Stretch"
                            Padding="15,9,15,0"
                            Margin="0,5,0,0" /> 
        </Border>
    </Grid>
</UserControl>