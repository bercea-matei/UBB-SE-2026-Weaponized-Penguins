<Page
    x:Class="Boards_WP.Views.Pages.FullPostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views.Pages"
    xmlns:views="using:Boards_WP.Views"
xmlns:helpers="using:Boards_WP.Helpers"
xmlns:viewmodels="using:Boards_WP.ViewModels"
xmlns:models="using:Boards_WP.Data.Models"
Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,20">

                <Button Click="Back_Click" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" />
                        <TextBlock Text=" Back to Feed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0FF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center"
                                    Background="#F8F8FF" CornerRadius="8" Padding="4" BorderBrush="#E0E0FF" BorderThickness="1">
                            <Button Content="▲" Command="{x:Bind ViewModel.UpvoteCommand}"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Score, Mode=OneWay}"
                                       HorizontalAlignment="Center" FontWeight="Bold" Foreground="#6A67E1"/>
                            <Button Content="▼" Command="{x:Bind ViewModel.DownvoteCommand}"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="15,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PersonPicture ProfilePicture="{x:Bind helpers:ImageHelper.ConvertToBitmap(ViewModel.CurrentPost.ParentCommunity.Picture), Mode=OneWay}"
                                                   DisplayName="{x:Bind ViewModel.CurrentPost.ParentCommunity.Name, Mode=OneWay}"
                                                   Height="36" Width="36"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.CurrentPost.ParentCommunity.Name, Mode=OneWay}"
                                                   FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{x:Bind ViewModel.CurrentPost.Owner.Username, Mode=OneWay}"
                                                   FontSize="12" Foreground="Gray"/>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentPost.Tags, Mode=OneWay}" Margin="0,5,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:Tag">
                                                    <Border CornerRadius="8" Padding="6,2" Background="{x:Bind helpers:ColorHelper.GetBrushForCategory(CategoryBelongingTo.CategoryID), Mode=OneWay}">
                                                        <TextBlock Text="{x:Bind TagName, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.CurrentPost.CreationTime, Mode=OneWay}"
                                           FontSize="11" Foreground="Silver" VerticalAlignment="Top"/>
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Title, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Description, Mode=OneWay}"
                                       TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,15"/>

                            <Image x:Name="PostImage" MaxHeight="400" Stretch="Uniform" Margin="0,0,0,10"
                                   Visibility="{x:Bind local:FullPostView.NullToVisibility(ViewModel.CurrentPost.Image), Mode=OneWay}"/>

                            <Button x:Name="ShowCommentBtn" 
                                    Command="{x:Bind ViewModel.ShowCommentAreaCommand}"
                                    Visibility="{x:Bind BooleanToInverseVisibility(ViewModel.IsCommentAreaVisible), Mode=OneWay}"
                                    Background="Transparent" BorderThickness="0" Padding="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8BD;" FontSize="16" Foreground="#6A67E1"/>
                                    <TextBlock Text="Write Comment" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6A67E1"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <Border BorderBrush="#E0E0FF" BorderThickness="1" CornerRadius="5" Padding="5">
                                <StackPanel>
                                    <FontIcon Glyph="&#xE8BD;" FontSize="18" Foreground="#6A67E1"/>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentPost.CommentsNumber, Mode=OneWay}"
                                               HorizontalAlignment="Center" FontSize="10"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,0,20" Padding="15" 
                        BorderBrush="#6A67E1" BorderThickness="2"
                        Visibility="{x:Bind BooleanToVisibility(ViewModel.IsCommentAreaVisible), Mode=OneWay}">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox x:Name="CommentInput" 
                                 PlaceholderText="Write a comment...." 
                                 Text="{x:Bind ViewModel.NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" 
                                 Background="Transparent" MinHeight="60"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="10" Margin="10,0,0,0">
                            <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommentCommand}" 
                                    Background="Transparent" BorderThickness="0"/>
                            <Button Content="Post Comment" Command="{x:Bind ViewModel.PostCommentCommand}"
                                    Background="#6A67E1" Foreground="White" CornerRadius="8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.PostComments, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Comment">
                            <views:CommentView CommentData="{x:Bind}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>