<UserControl
    x:Class="Boards_WP.Views.PostPreviewForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:viewmodels="using:Boards_WP.ViewModels">

    <Grid Background="White" CornerRadius="12" Padding="15" BorderBrush="#E0E0FF" BorderThickness="1"
          PointerPressed="OnPostClicked" PointerEntered="Grid_PointerEntered" PointerExited="Grid_PointerExited">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Background="#F8F8FF" CornerRadius="8" Padding="4">
            <Button Content="▲" Command="{x:Bind ViewModel.UpvoteCommand, Mode=OneWay}" Background="Transparent" BorderThickness="0"/>
            <TextBlock Text="{x:Bind ViewModel.PostData.Score, Mode=OneWay}" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#6A67E1"/>
            <Button Content="▼" Command="{x:Bind ViewModel.DownvoteCommand, Mode=OneWay}" Background="Transparent" BorderThickness="0"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="15,0">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                <TextBlock Text="{x:Bind ViewModel.PostData.ParentCommunity.Name, Mode=OneWay}" FontWeight="Bold"/>
                <TextBlock Text="{x:Bind ViewModel.PostData.Owner.Username, Mode=OneWay}" Foreground="Gray"/>
                <TextBlock Text="{x:Bind ViewModel.FormattedDate, Mode=OneWay}" Foreground="Silver" FontSize="11"/>
            </StackPanel>
            <TextBlock Text="{x:Bind ViewModel.PostData.Title, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{x:Bind ViewModel.PostData.Description, Mode=OneWay}" TextWrapping="Wrap" Foreground="#444"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="10">
            <Border BorderBrush="#E0E0FF" BorderThickness="1" CornerRadius="5" Padding="5">
                <StackPanel>
                    <FontIcon Glyph="&#xE8BD;" FontSize="18" Foreground="#6A67E1"/>
                    <TextBlock Text="{x:Bind ViewModel.PostData.CommentsNumber, Mode=OneWay}" HorizontalAlignment="Center" FontSize="10"/>
                </StackPanel>
            </Border>

            <Button Command="{x:Bind ViewModel.DeleteCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.DeleteButtonVisibility, Mode=OneWay}"
                    Background="Transparent" BorderThickness="0">
                <FontIcon Glyph="&#xE74D;" Foreground="Red" FontSize="18"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>