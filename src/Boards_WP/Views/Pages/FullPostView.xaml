<Page
    x:Class="Boards_WP.Views.Pages.FullPostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views.Pages"
    xmlns:views="using:Boards_WP.Views"
    xmlns:viewmodels="using:Boards_WP.ViewModels"
    xmlns:models="using:Boards_WP.Data.Models"
    Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,20">

                <Button Click="Back_Click" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" />
                        <TextBlock Text=" Back to Feed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>
                

                

               <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0FF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center"
                                    Background="#F8F8FF" CornerRadius="8" Padding="4" BorderBrush="#E0E0FF" BorderThickness="1">
                            <Button Content="▲" Command="{x:Bind ViewModel.UpvoteCommand}"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Score, Mode=OneWay}"
                                       HorizontalAlignment="Center" FontWeight="Bold" Foreground="white"/>
                            <Button Content="▼" Command="{x:Bind ViewModel.DownvoteCommand}"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="15,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentPost.ParentCommunity.Name, Mode=OneWay}"
                                               FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentPost.Owner.Username, Mode=OneWay}"
                                               FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.CurrentPost.CreationTime, Mode=OneWay}"
                                           FontSize="11" Foreground="Silver" VerticalAlignment="Top"/>
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Title, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="{x:Bind ViewModel.CurrentPost.Description, Mode=OneWay}"
                                       TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,15"/>

                            <Image x:Name="PostImage" MaxHeight="400" Stretch="Uniform" Margin="0,0,0,10"
                                   Visibility="{x:Bind local:FullPostView.NullToVisibility(ViewModel.CurrentPost.Image), Mode=OneWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <Border BorderBrush="#E0E0FF" BorderThickness="1" CornerRadius="5" Padding="5">
                                <StackPanel>
                                    <FontIcon Glyph="&#xE8BD;" FontSize="18" Foreground="white"/>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentPost.CommentsNumber, Mode=OneWay}"
                                               HorizontalAlignment="Center" FontSize="10"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="12" Margin="0,0,0,20" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox PlaceholderText="Write a comment...." 
                                 Text="{x:Bind ViewModel.NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" Background="Transparent" MinHeight="40"/>
                        
                        <Button Grid.Column="1" Content="Post Comment" 
                                Command="{x:Bind ViewModel.PostCommentCommand}"
                                Background="#6A67E1" Foreground="White" CornerRadius="8" VerticalAlignment="Bottom" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.PostComments, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Comment">
                            <views:CommentView CommentData="{x:Bind}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>