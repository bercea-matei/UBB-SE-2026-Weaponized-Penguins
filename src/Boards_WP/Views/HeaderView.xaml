<UserControl
    x:Class="Boards_WP.Views.HeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models" 
    xmlns:helpers="using:Boards_WP.Helpers"
    xmlns:views="using:Boards_WP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Thickness x:Key="AutoSuggestBoxBorderThicknessFocused">0</Thickness>
        <SolidColorBrush x:Key="AutoSuggestBoxBorderBrushFocused" Color="Transparent"/>
        <SolidColorBrush x:Key="AutoSuggestBoxBottomBorderBrushFocused" Color="Transparent"/>
    </UserControl.Resources>
    
    <Grid Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" Height="80" Padding="20,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/> <ColumnDefinition Width="*"/>   <ColumnDefinition Width="250"/> </Grid.ColumnDefinitions>

        <Image Source="ms-appx:///Assets/WPLogo.png" 
               Width="200" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Center"
               Margin="40,0,0,5"/>
              
        <Grid Grid.Column="1" VerticalAlignment="Center" MaxWidth="800" HorizontalAlignment="Stretch">
            <Border x:Name="SearchBoxBorder" Background="White" CornerRadius="20" Height="40">
                <AutoSuggestBox x:Name="CommunitySearchBox"
                                PlaceholderText="Search communities..."
                                QueryIcon="Find"
                                Background="Transparent"
                                BorderThickness="0" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Stretch"
                                Padding="15,9,15,0"
                                Margin="0,5,0,0"
                                TextChanged="CommunitySearchBox_TextChanged"
                                ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                                UpdateTextOnSelect="False"
                                SuggestionChosen="CommunitySearchBox_SuggestionChosen">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Community">
                            <StackPanel Orientation="Horizontal" Padding="10">
                                <PersonPicture ProfilePicture="{x:Bind helpers:ImageHelper.ConvertToBitmap(Picture), Mode=OneWay}"
                                               DisplayName="{x:Bind Name}" 
                                               Height="32" Width="32" Margin="0,0,10,0"
                                               Visibility="{x:Bind views:HeaderView.GetVisibilityFromId(CommunityID)}"/>
                                <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </Border>
            <TextBlock Text="No matches found"
                       HorizontalAlignment="Center"
                       Foreground="Gray"
                       Margin="0,50,0,0"
                       Visibility="{x:Bind GetVisibility(ViewModel.NoResultsToggle), Mode=OneWay}"/>
        </Grid>

        <StackPanel x:Name="TokenDisplay" 
                    Grid.Column="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10" 
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xEB1B;" Foreground="Gold" VerticalAlignment="Center" FontSize="20"/>
            <TextBlock x:Name="TokenCountText" 
                       Text="1250" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>
            <TextBlock Text="Tokens" 
                       Foreground="#6A67E1" 
                       VerticalAlignment="Center" 
                       Margin="0,4,0,0" 
                       FontSize="14"/>
        </StackPanel>
    </Grid>
</UserControl>