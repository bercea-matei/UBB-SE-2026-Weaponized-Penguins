<UserControl
    x:Class="Boards_WP.Views.HeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Thickness x:Key="AutoSuggestBoxBorderThicknessFocused">0</Thickness>
        <SolidColorBrush x:Key="AutoSuggestBoxBorderBrushFocused" Color="Transparent"/>
        <SolidColorBrush x:Key="AutoSuggestBoxBottomBorderBrushFocused" Color="Transparent"/>
    </UserControl.Resources>
    
    <Grid Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" Height="80" Padding="20,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="ms-appx:///Assets/WPLogo.png" 
               Width="200" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Center"
               Margin="40,0,0,5"/>
              
        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,120,0" MaxWidth="800" HorizontalAlignment="Stretch">
            <Border x:Name="SearchBoxBorder" Background="White" CornerRadius="20" Height="40">
                <AutoSuggestBox x:Name="CommunitySearchBox"
                                PlaceholderText="Search communities..."
                                QueryIcon="Find"
                                Background="Transparent"
                                BorderThickness="0" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Stretch"
                                Padding="15,9,15,0"
                                Margin="0,5,0,0"
                                TextChanged="CommunitySearchBox_TextChanged"
                ></AutoSuggestBox>
            </Border>

            <Popup x:Name="ResultsPopup" 
               VerticalOffset="45" 
               HorizontalOffset="0"
               IsLightDismissEnabled="True">
                <Border Background="White" 
                    CornerRadius="0,0,15,15" 
                    BorderBrush="#6A67E1" 
                    BorderThickness="1">   
                    <ListView x:Name="ResultsList" 
                      SelectionMode="None" 
                      IsItemClickEnabled="True"
                      ItemClick="ResultsList_ItemClick"
                      ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Community">
                                <StackPanel Orientation="Horizontal" Padding="10">
                                    <SymbolIcon Symbol="People" Margin="0,0,10,0" Foreground="#6A67E1"/>
                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Popup>

            <TextBlock Text="No matches found" 
               HorizontalAlignment="Center" 
               Foreground="Gray"
               Margin="0,50,0,0"
               Visibility="{x:Bind GetVisibility(ViewModel.NoResultsToggle), Mode=OneWay}"/>
        </Grid>
    </Grid>
</UserControl>