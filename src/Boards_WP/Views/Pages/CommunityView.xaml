<Page
    x:Class="Boards_WP.Views.Pages.CommunityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:views="using:Boards_WP.Views"
    xmlns:viewmodels="using:Boards_WP.ViewModels"
    Background="Transparent">

    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="10">
                <Grid Height="250">
                    <Border Height="200" VerticalAlignment="Top" CornerRadius="0,0,15,15" Background="#FFFFFF">
                        <Image Source="{x:Bind ViewModel.BannerImage, Mode=OneWay}" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="30,0,0,10">
                        <PersonPicture ProfilePicture="{x:Bind ViewModel.ProfileImage, Mode=OneWay}"
                                       DisplayName="{x:Bind ViewModel.CurrentCommunity.Name, Mode=OneWay}"
                                       Height="80" Width="80" BorderBrush="White" BorderThickness="4"/>

                        <StackPanel Margin="15,40,0,0">
                            <TextBlock Text="{x:Bind ViewModel.CurrentCommunity.Name, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold" Foreground="Black"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind ViewModel.MemberCountText, Mode=OneWay}"
                                           FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>

                                <Button Content="Join Community"
                                        Command="{x:Bind ViewModel.JoinCommand}"
                                        Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" Foreground="White" CornerRadius="8"
                                        Visibility="{x:Bind ViewModel.JoinButtonVisibility, Mode=OneWay}"/>

                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            Visibility="{x:Bind ViewModel.MemberActionsVisibility, Mode=OneWay}">
                                    <Button Content="Create Post"
                                            Command="{x:Bind ViewModel.CreatePostCommand}"
                                            Background="White" BorderBrush="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" BorderThickness="1" CornerRadius="8"/>
                                    <Button Content="Edit Community"
                                            Command="{x:Bind ViewModel.EditCommunityCommand}"
                                            Background="White" BorderBrush="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" BorderThickness="1" CornerRadius="8"
                                            Visibility="{x:Bind ViewModel.EditButtonVisibility, Mode=OneWay}"/>
                                    <Button Content="Leave Community"
                                            Command="{x:Bind ViewModel.LeaveCommand}"
                                            Background="#FFE0E0" Foreground="Red" BorderBrush="Red" BorderThickness="1" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" CornerRadius="12" Margin="20,0" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <TextBlock Text="{x:Bind ViewModel.CurrentCommunity.Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="15"/>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.CommunityPosts, Mode=OneWay}" Margin="20,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:PostPreviewViewModel">
                            <views:PostPreviewForm Margin="0,0,0,15"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
