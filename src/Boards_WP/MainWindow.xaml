<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Boards_WP.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP"
    xmlns:views="using:Boards_WP.Views"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Boards_WP">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#E6E2FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <views:HeaderView Grid.Row="0" />

        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <views:CommunityBarView Grid.Column="0"/>

            <Grid Grid.Column="1" Margin="4">
                <ListView x:Name="FeedList" 
                          SelectionMode="None" 
                          Padding="0,0,10,0"
                          Background="Transparent">
                    
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Post">
                            <views:PostPreviewForm PostData="{x:Bind}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <views:NotificationsView Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>